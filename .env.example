# =============================================
# autopilot 設定ファイル
# cp .env.example .env して編集してください
# =============================================

# ---- 通知バックエンド ----

# "local" = macOS 通知 + ターミナル stdin 承認
# "slack" = Slack Socket Mode
# 未設定時のデフォルト: local
NOTIFY_BACKEND=local

# ---- Obsidian Vault ----

# Vault のルートパス（絶対パス）
VAULT_PATH=/PATH_TO_YOUR_VAULT

# 監視するプロジェクト名
# Vault 内の Projects/{WATCH_PROJECT}/stories/ を監視する
WATCH_PROJECT=my-project

# ---- Slack (Socket Mode) ----

# Bot Token（xoxb-...）
# Slack App の「OAuth & Permissions」から取得
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token（xapp-...）Socket Mode 用
# Slack App の「Basic Information > App-Level Tokens」から生成（connections:write スコープ）
SLACK_APP_TOKEN=xapp-your-app-token

# 通知を送る Slack チャンネル ID（C から始まる ID）
SLACK_CHANNEL_ID=C0123456789
