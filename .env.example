# =============================================
# claude-workflow-kit 設定ファイル
# cp .env.example .env して編集してください
# =============================================

# ---- Obsidian Vault ----

# Vault のルートパス（絶対パス）
VAULT_PATH=/Users/yourname/Documents/Dev/Dev

# ---- Slack (Socket Mode) ----

# Bot Token（xoxb-...）
# Slack App の「OAuth & Permissions」から取得
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token（xapp-...）Socket Mode 用
# Slack App の「Basic Information > App-Level Tokens」から生成（connections:write スコープ）
SLACK_APP_TOKEN=xapp-your-app-token

# 通知を送る Slack チャンネル ID（C から始まる ID）
SLACK_CHANNEL_ID=C0123456789

# ---- Temporal ----

# Temporal サーバーアドレス（デフォルト: localhost:7233）
# ローカル開発: temporal server start-dev --db-file=./temporal.db
TEMPORAL_ADDRESS=localhost:7233

# タスクキュー名
TEMPORAL_TASK_QUEUE=claude-workflow-kit
