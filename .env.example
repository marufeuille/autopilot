# =============================================
# claude-workflow-kit 設定ファイル
# cp .env.example .env して編集してください
# =============================================

# 通知モード: slack | local
# local: macOSネイティブダイアログ（osascript）またはターミナル入力
# slack: Slack通知 + n8n経由でボタン応答待ち
NOTIFICATION_MODE=local

# ---- Slack モード時のみ必要 ----

# n8n の通知受信 Webhook URL（workflow-notify の URL）
N8N_NOTIFY_WEBHOOK_URL=https://your-n8n.example.com/webhook/cwk-notify

# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-token-here

# 通知を送るSlackチャンネルID
SLACK_CHANNEL_ID=C0123456789

# n8n から折り返しHTTPコールバックする際のホスト名
# n8n を Docker で動かす場合は host.docker.internal
# n8n をローカルで直接動かす場合は localhost
N8N_CALLBACK_HOST=host.docker.internal

# ---- Obsidian 設定 ----

# Obsidian Vault 名（obsidian vault= に渡す値）
OBSIDIAN_VAULT=Dev

# GitHub CLI 認証済みであることを確認してください: gh auth status
